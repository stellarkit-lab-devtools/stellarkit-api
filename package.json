{
  "name": "stellarkit-api",
  "version": "1.0.0",
  "description": "A developer utility API for the Stellar blockchain — fee estimation, account info, transaction history, network status, and asset metadata via Horizon.",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "seed": "node scripts/seed-testnet.js"
  },
  "keywords": [
    "stellar",
    "blockchain",
    "horizon",
    "api",
    "express",
    "stellar-sdk",
    "defi",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "morgan": "^1.10.0",
    "node-cache": "5.1.2",
    "toml": "^3.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3"
  }
}
