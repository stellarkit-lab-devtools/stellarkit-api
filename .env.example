# Stellar Network — use "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Horizon server URL (optional override)
# Testnet default: https://horizon-testnet.stellar.org
# Mainnet default: https://horizon.stellar.org
HORIZON_URL=

# Server config
PORT=3000
NODE_ENV=development

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# Cache TTL for network-status and fee-estimate endpoints (milliseconds)
# Default: 5000 (5 seconds)
CACHE_TTL_MS=5000
