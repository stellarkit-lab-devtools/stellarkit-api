# Stellar Network — use "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Horizon server URL (optional override)
# Testnet default: https://horizon-testnet.stellar.org
# Mainnet default: https://horizon.stellar.org
HORIZON_URL=

# Server config
PORT=3000
NODE_ENV=development

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# Cache TTL for network-status and fee-estimate endpoints (milliseconds)
# Default: 5000 (5 seconds)
CACHE_TTL_MS=5000

# Cache TTL for GET /dex/top-markets (milliseconds)
# Default: 10000 (10 seconds)
CACHE_TTL_TOP_MARKETS_MS=10000

# Trading pairs tracked by GET /dex/top-markets, quoted against XLM.
# Comma-separated "CODE:ISSUER" list. Defaults to Circle's official USDC issuer.
# Example: DEX_TOP_MARKETS=USDC:GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
DEX_TOP_MARKETS=
